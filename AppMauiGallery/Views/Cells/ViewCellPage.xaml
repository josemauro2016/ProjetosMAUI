<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMauiGallery.Views.Cells.ViewCellPage"
             Title="ViewCellPage">
    <VerticalStackLayout>
        <TableView>
            <TableSection Title="Colaboradores">
                <ViewCell>
                    <Grid ColumnDefinitions="70, *, 70">
                        <Image Source="dotnet_bot.png" 
                               MaximumHeightRequest="50" 
                               MaximumWidthRequest="50"/>
                        <VerticalStackLayout Grid.Column="1">
                        <Label
                            Text="Creysson da silva" 
                            Margin="10, 0, 0, 0"
                            FontSize="24"/>
                        <Label
                            Margin="10, 0, 0, 0"
                            Text="(CEO) Grupo Capivara seu Creysson"
                            FontSize="12"/>
                        </VerticalStackLayout>
                        <Button 
                            Grid.Column="2" 
                            Text="Excluir"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>
                    </Grid>
                </ViewCell>
            </TableSection>
        </TableView>
    </VerticalStackLayout>
</ContentPage>