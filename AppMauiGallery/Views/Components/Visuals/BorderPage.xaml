<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMauiGallery.Views.Components.Visuals.BorderPage"
             Title="BorderPage">
    <VerticalStackLayout Padding="10">
        <Border Padding="10"
                Stroke="Blue"
                StrokeThickness="10"
                
                StrokeLineJoin="Round"
                StrokeLineCap="Round"
                
                StrokeDashArray="1,3,1"
                StrokeDashOffset="5">
            <Label 
                Text="Welcome to .NET MAUI!"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />
        </Border>
        <Border Padding="10" 
                Margin="0, 10, 0, 10"
                Stroke="Blue"
                StrokeShape="RoundRectangle 5, 10, 15, 20">
            <Label Text="Minha primeira borda" />
        </Border>
    </VerticalStackLayout>
</ContentPage>