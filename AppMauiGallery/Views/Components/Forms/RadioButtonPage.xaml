<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMauiGallery.Views.Components.Forms.RadioButtonPage"
             Title="RadioButtonPage">
    <VerticalStackLayout Padding="10">
        <StackLayout>
            <Label 
                Text="Qual a sua linguagem de programação preferida?"
                VerticalOptions="Center" 
                HorizontalOptions="Start" />
            <RadioButton Content="C#" />
            <RadioButton Content="Java"/>
            <RadioButton Content="JavaScript"/>
        </StackLayout>
        <StackLayout RadioButtonGroup.GroupName="ask02">
            <Label 
                Text="Qual a linguagem de programação você evita?"
                VerticalOptions="Center" 
                HorizontalOptions="Start" />
            <RadioButton Value="Robot">
                <RadioButton.Content>
                    <HorizontalStackLayout>
                        <Label Text="Robot" />
                        <Image Source="dotnet_bot.png" HeightRequest="30"/>
                    </HorizontalStackLayout>
                </RadioButton.Content>
            </RadioButton>
            <RadioButton Content="Java"/>
            <RadioButton Content="JavaScript"/>
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>