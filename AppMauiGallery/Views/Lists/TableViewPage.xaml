<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMauiGallery.Views.Lists.TableViewPage"
             Title="TableViewPage">
    <VerticalStackLayout>
        <TableView Margin="10" HasUnevenRows="True" Intent="Settings">
            <TableRoot>
                <TableSection Title="Segurança">
                    <EntryCell Label="Modificar senha"/>
                </TableSection>
                <TableSection Title="Backup">
                    <SwitchCell Text="Habilitar Backup"/>
                    <SwitchCell Text="Backup diário"/>
                    <SwitchCell Text="Backup semanal"/>
                    <SwitchCell Text="Backup mensal"/>
                </TableSection>
            </TableRoot>
        </TableView>
    </VerticalStackLayout>
</ContentPage>